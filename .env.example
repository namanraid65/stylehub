# ╔══════════════════════════════════════════════════════════════╗
# ║              StyleHub — Root Environment Variables           ║
# ║   Copy this file to .env and fill in your actual values.    ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Node ─────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── API ──────────────────────────────────────────────────────────────────────────
API_PORT=5000
API_URL=http://localhost:5000

# ── Frontend URLs (for CORS + email links) ───────────────────────────────────────
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ── MongoDB ───────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/stylehub
# Production example:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/stylehub?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────────
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_long_random_string_access
JWT_REFRESH_SECRET=replace_with_a_long_random_string_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cloudinary ────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
# For Stripe Connect (vendor payouts):
STRIPE_PLATFORM_ACCOUNT_ID=acct_

# ── Email — Resend ────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_
EMAIL_FROM=StyleHub <noreply@stylehub.in>

# ── Misc ──────────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
