{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@stylehub/types": ["../../../packages/types/src"],
      "@stylehub/validators": ["../../../packages/validators/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "src/scripts/**/*"]
}
